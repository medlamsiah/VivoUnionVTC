generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Lead {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  fullName      String
  email         String?
  phone         String?
  city          String?
  hasCardVTC    Boolean
  hasVehicle    Boolean
  experience    String   // "0-1", "1-3", "3+"
  platforms     String   // csv
  weeklyHours   Int?
  message       String?

  // simulation history optional
  simulations   Simulation[]
}

model Simulation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  ca        Float
  net       Float
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([leadId])
}

model DriverWeeklySetting {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  driverName    String
  driverNameKey String
  weekValue     String
  vehicleType   String?
  location      Float    @default(0)
  acompte       Float    @default(0)

  @@unique([driverNameKey, weekValue])
  @@index([driverName])
  @@index([weekValue])
}

model LocationTypePricing {
  key        String   @id
  label      String
  price      Float
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}
