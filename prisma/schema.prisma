generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Lead {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  fullName      String
  email         String?
  phone         String?
  city          String?
  hasCardVTC    Boolean
  hasVehicle    Boolean
  experience    String   // "0-1", "1-3", "3+"
  platforms     String   // csv
  weeklyHours   Int?
  message       String?

  // simulation history optional
  simulations   Simulation[]
}

model Simulation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  ca        Float
  net       Float
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([leadId])
}

model DriverWeeklySetting {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  driverName    String
  driverNameKey String
  weekValue     String
  vehicleType   String?
  location      Float    @default(0)
  acompte       Float    @default(0)

  @@unique([driverNameKey, weekValue])
  @@index([driverName])
  @@index([weekValue])
}

model LocationTypePricing {
  key        String   @id
  label      String
  price      Float
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}
model PlatformWeeklyRevenue {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  platform      String   // uber, bolt, heetch
  driverName    String
  driverNameKey String
  company       String
  weekValue     String
  week          String

  gross         Float    @default(0)
  net           Float    @default(0)
  payout        Float    @default(0)
  adjustments   Float    @default(0)
  reimbursements Float   @default(0)

  @@unique([platform, driverNameKey, weekValue])
  @@index([platform])
  @@index([driverName])
  @@index([weekValue])
}
model UberDriverRevenueSnapshot {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  snapshotDate  DateTime
  periodStart   DateTime
  periodEnd     DateTime

  driverUuid    String
  driverName    String
  driverNameKey String

  totalRevenue  Float @default(0)
  netTripPrice  Float @default(0)
  bonus         Float @default(0)
  reimbursements Float @default(0)
  payouts       Float @default(0)
  bankTransfers Float @default(0)
  cashCollected Float @default(0)
  thirdPartyPaid Float @default(0)
  tolls         Float @default(0)
  postTripAdjustments Float @default(0)
  tips          Float @default(0)
  otherAdjustments Float @default(0)

  @@unique([snapshotDate, periodStart, periodEnd, driverUuid])
  @@index([driverName])
  @@index([snapshotDate])
  @@index([periodStart, periodEnd])
}

model UberEarning {
  id             String   @id @default(cuid())
  externalId     String   @unique
  driverName     String
  revenue        Float    @default(0)
  reimbursements Float    @default(0)
  adjustments    Float    @default(0)
  payout         Float    @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  raw            Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([driverName])
  @@index([periodStart, periodEnd])
  @@index([updatedAt])
}

model UberSession {
  id                    String   @id @default(cuid())
  provider              String   @unique @default("uber")
  cookieCiphertext       String?  @db.Text
  csrfTokenCiphertext    String?  @db.Text
  orgUuid               String?
  status                String   @default("missing")
  lastValidatedAt       DateTime?
  lastError             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
}
